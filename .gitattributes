# Handle line endings
* text=auto

# UE5 Binary Assets (Git LFS)
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

# Raw Content/Audio/Video (Git LFS)
*.fbx *.obj *.psd *.png *.jpg *.jpeg *.tga *.bmp *.exr filter=lfs diff=lfs merge=lfs -text
*.wav *.mp3 *.ogg *.mp4 *.mov *.pdf filter=lfs diff=lfs merge=lfs -text
